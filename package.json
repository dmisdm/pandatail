{
  "name": "@dmisdm/pandatail",
  "version": "0.1.0",
  "description": "PandaCSS preset that mirrors every token in your Tailwind v4 @theme into typed Panda style props. One source of truth, full TS type safety.",
  "license": "MIT",
  "keywords": [
    "pandacss",
    "panda-preset",
    "tailwindcss",
    "tailwind",
    "tailwind-v4",
    "design-tokens",
    "typescript",
    "preset",
    "css-in-js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmisdm/pandatail.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run clean && bun run build:js && bun run build:types",
    "build:js": "bun build src/index.ts --outdir dist --target node --format esm --external @pandacss/dev --external tailwindcss --external postcss",
    "build:types": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "bun test",
    "prepublishOnly": "bun run test && bun run build"
  },
  "peerDependencies": {
    "@pandacss/dev": "^1.0.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "dependencies": {
    "postcss": "^8.4.0"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.11.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bun": "latest",
    "@types/node": "^25.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5"
  }
}